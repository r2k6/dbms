CODE

3 DECLARE
ID INTEGER;
SAL INTEGER;
BEGIN
ID:=&ID;
SELECT SALARY INTO SAL
FROM EMPLOYEE WHERE EMP_ID=ID;
DBMS_OUTPUT.PUT_LINE('Salary is:'||SAL);

END;
